{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1",
    "^@src/(.*)$": "<rootDir>/src/$1",
    "^@database/(.*)$": "<rootDir>/database/$1",
    "^@testInfra/(.*)$": "<rootDir>/test/$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "setupFiles": ["<rootDir>/test/setup.ts"],
  "verbose": true,
  "resetMocks": true,
  "testMatch": ["<rootDir>/src/__test__/e2e/*.spec.ts"]
}
